# 腾讯云 + COS 环境变量（生产）
# 复制为 .env 后填入真实值，勿提交 .env 到 Git

PORT=3000
NODE_ENV=production

# 对外公开 URL（Mock JSON 内链、文档示例；生产填 CDN 或 API 域名）
DEVIMAGE_PUBLIC_URL=http://localhost:3000

# --- 腾讯云 CAM（建议子账号，仅授予 COS 读写）---
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# --- COS 对象存储 ---
COS_REGION=ap-guangzhou
COS_BUCKET=devimage-1250000000
COS_PHOTO_PREFIX=photos/

# COS 绑定的 CDN 自定义域名（Phase 2 /photo 302 用，可选）
COS_CDN_DOMAIN=https://cdn.devimage.cn
