# 腾讯云 + COS 环境变量（生产）
# 复制为 .env 后填入真实值，勿提交 .env 到 Git

PORT=3000
NODE_ENV=production

# 对外公开 URL（Mock JSON 内链、文档示例；生产填 CDN 或 API 域名）
DEVIMAGE_PUBLIC_URL=http://localhost:3000

# --- 腾讯云 CAM（建议子账号，仅授予 COS 读写）---
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# --- COS 对象存储 ---
COS_REGION=ap-beijing
COS_BUCKET=devimage-1250000000
COS_PHOTO_PREFIX=photos/

# COS 绑定的 CDN 自定义域名（Phase 2 /photo 302 用，可选）
COS_CDN_DOMAIN=https://cdn.devimage.cn

# --- 真实图库（/photo）---
# manifest JSON 目录（默认 apps/api/data/photo）
PHOTO_MANIFEST_DIR=data/photo
# 响应模式：local=API 从 COS 读原图并裁剪直出；redirect=302 到 CDN（需 COS_CDN_DOMAIN）
PHOTO_SERVE_MODE=local
# 无 CDN 时可设 1，302 到 COS 默认域名（Bucket 需公有读或使用签名）
PHOTO_USE_COS_DIRECT_URL=0
# 无 CDN 时的 COS 公网前缀（可选，如 https://bucket.cos.ap-beijing.myqcloud.com）
COS_PUBLIC_BASE=
COS_SEED_PREFIX=assets/seed-pack/
COS_MANIFEST_PREFIX=manifest/
